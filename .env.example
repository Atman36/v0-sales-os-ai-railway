NODE_ENV=production
API_PORT=4000

# PostgreSQL — задать в Railway (автоматически из сервиса PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me
AUTH_TOKEN_REVOCATION_BACKEND=database
SALESOS_WEBHOOK_SECRET=change-me

# Аккаунт администратора bootstrap seed (admin@salesos.ai / admin123)
ADMIN_EMAIL=admin@salesos.ai
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# Создать demo-менеджеров (mgr-001, mgr-002, mgr-003 / manager123) только при явном bootstrap
SEED_DEMO_MANAGERS=false

# Настройки
TENANT_TIMEZONE=UTC
CALL_PROCESSING_ENABLED=false
DAILY_METRICS_SOURCE_OF_TRUTH=manual_reports
AI_ENABLED=false
AI_PROVIDER=stub

# Redis — нужен только если CALL_PROCESSING_ENABLED=true
# REDIS_URL=redis://localhost:6379
